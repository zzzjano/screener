generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MarketType {
  SPOT
  LINEAR
  INVERSE
}

enum ScreenerStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum IndicatorKind {
  RSI
  SMA
  EMA
  MACD
  BOLLINGER_BANDS
  ATR
  ADX
  STOCH_RSI
  VWAP
  OBV
  MFI
  ROC
  CCI
  CUSTOM
}

enum PriceSource {
  OPEN
  HIGH
  LOW
  CLOSE
  HL2
  HLC3
  OHLC4
}

enum TriggerPolicy {
  ON_ENTER
  EVERY_CLOSED_CANDLE
  ON_STATE_CHANGE
}

enum AlertDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED_COOLDOWN
}

enum BacktestStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum BacktestExitKind {
  TAKE_PROFIT_STOP_LOSS
  BARS_ELAPSED
  EITHER
}

enum ApiKeyStatus {
  ACTIVE
  DISABLED
  REVOKED
  ERROR
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  displayName         String?
  passwordHash        String?
  locale              String               @default("pl")
  timezone            String               @default("Europe/Warsaw")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  screeners           Screener[]
  indicatorPresets    IndicatorPreset[]
  telegramConnections TelegramConnection[]
  backtestRuns        BacktestRun[]
  exchangeCredentials UserExchangeCredential[]
  portfolioSnapshots  PortfolioSnapshot[]
  positionSnapshots   PositionSnapshot[]
}

model TelegramConnection {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatIdEncrypted String
  username        String?
  isEnabled       Boolean   @default(true)
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, isEnabled])
}

model Market {
  id              String     @id @default(cuid())
  exchange        String     @default("bybit")
  type            MarketType
  symbol          String
  baseAsset       String
  quoteAsset      String
  isActive        Boolean    @default(true)
  precision       Json?
  limits          Json?
  coingeckoId     String?
  sectorTags      String[]   @default([])
  sectorUpdatedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([exchange, type, symbol])
  @@index([exchange, type, isActive])
  @@index([coingeckoId])
}

model Screener {
  id                   String          @id @default(cuid())
  userId               String
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                 String
  description          String?
  status               ScreenerStatus  @default(DRAFT)
  marketType           MarketType      @default(LINEAR)
  quoteAsset           String          @default("USDT")
  symbols              String[]
  timeframes           String[]
  ruleTree             Json
  ruleTreeHash         String
  compiledDependencies Json?
  triggerPolicy        TriggerPolicy   @default(ON_ENTER)
  cooldownSeconds      Int             @default(900)
  lastEvaluatedAt      DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  alerts               Alert[]
  matches              ScreenerMatch[]

  @@index([userId, status])
  @@index([status, marketType])
  @@index([ruleTreeHash])
}

model IndicatorPreset {
  id        String        @id @default(cuid())
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  kind      IndicatorKind
  timeframe String
  source    PriceSource   @default(CLOSE)
  params    Json
  isSystem  Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([userId, isSystem, kind])
}

model ScreenerMatch {
  id              String   @id @default(cuid())
  screenerId      String
  screener        Screener @relation(fields: [screenerId], references: [id], onDelete: Cascade)
  symbol          String
  timeframe       String
  candleCloseTime DateTime
  matched         Boolean
  score           Decimal? @db.Decimal(18, 8)
  snapshot        Json
  createdAt       DateTime @default(now())

  @@unique([screenerId, symbol, timeframe, candleCloseTime])
  @@index([screenerId, createdAt])
  @@index([symbol, timeframe, candleCloseTime])
}

model Alert {
  id              String          @id @default(cuid())
  screenerId      String
  screener        Screener        @relation(fields: [screenerId], references: [id], onDelete: Cascade)
  isEnabled       Boolean         @default(true)
  telegramEnabled Boolean         @default(true)
  messageTemplate String?
  cooldownSeconds Int             @default(900)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deliveries      AlertDelivery[]

  @@index([screenerId, isEnabled])
}

model AlertDelivery {
  id                String              @id @default(cuid())
  alertId           String
  alert             Alert               @relation(fields: [alertId], references: [id], onDelete: Cascade)
  screenerMatchId   String
  status            AlertDeliveryStatus @default(PENDING)
  message           String
  provider          String              @default("telegram")
  providerMessageId String?
  error             String?
  attempts          Int                 @default(0)
  nextRetryAt       DateTime?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())

  @@unique([alertId, screenerMatchId])
  @@index([status, nextRetryAt])
}

model HistoricalCandle {
  id         BigInt     @id @default(autoincrement())
  exchange   String     @default("bybit")
  marketType MarketType
  symbol     String
  timeframe  String
  openTime   DateTime
  closeTime  DateTime
  open       Decimal    @db.Decimal(30, 12)
  high       Decimal    @db.Decimal(30, 12)
  low        Decimal    @db.Decimal(30, 12)
  close      Decimal    @db.Decimal(30, 12)
  volume     Decimal    @db.Decimal(30, 12)
  turnover   Decimal?   @db.Decimal(30, 12)
  createdAt  DateTime   @default(now())

  @@unique([exchange, marketType, symbol, timeframe, openTime])
  @@index([symbol, timeframe, openTime])
  @@index([exchange, marketType, timeframe, openTime])
}

model DerivativeMetric {
  id                 BigInt     @id @default(autoincrement())
  exchange           String     @default("bybit")
  marketType         MarketType
  symbol             String
  timestamp          DateTime
  openInterest       Decimal?   @db.Decimal(30, 12)
  openInterestValue  Decimal?   @db.Decimal(30, 12)
  fundingRate        Decimal?   @db.Decimal(18, 12)
  liquidationBuyQty  Decimal?   @db.Decimal(30, 12)
  liquidationSellQty Decimal?   @db.Decimal(30, 12)
  createdAt          DateTime   @default(now())

  @@unique([exchange, marketType, symbol, timestamp])
  @@index([symbol, timestamp])
}

model BacktestRun {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  screenerId  String?
  name        String?
  ruleTree    Json
  symbols     String[]
  timeframes  String[]
  startTime   DateTime
  endTime     DateTime
  status      BacktestStatus @default(PENDING)
  exitKind    BacktestExitKind
  exitConfig  Json
  metrics     Json?
  error       String?
  createdAt   DateTime       @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  signals     BacktestSignal[]

  @@index([userId, status])
  @@index([status, createdAt])
}

model BacktestSignal {
  id                         String      @id @default(cuid())
  runId                      String
  run                        BacktestRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  symbol                     String
  timeframe                  String
  signalTime                 DateTime
  entryPrice                 Decimal     @db.Decimal(30, 12)
  exitTime                   DateTime?
  exitPrice                  Decimal?    @db.Decimal(30, 12)
  pnlPct                     Decimal?    @db.Decimal(18, 8)
  maxAdverseExcursionPct     Decimal?    @db.Decimal(18, 8)
  maxFavorableExcursionPct   Decimal?    @db.Decimal(18, 8)
  snapshot                   Json
  createdAt                  DateTime    @default(now())

  @@index([runId, signalTime])
  @@index([symbol, timeframe, signalTime])
}

model UserExchangeCredential {
  id                  String       @id @default(cuid())
  userId              String
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchange            String       @default("bybit")
  label               String?
  apiKeyCiphertext    String
  apiKeyIv            String
  apiKeyAuthTag       String
  apiSecretCiphertext String
  apiSecretIv         String
  apiSecretAuthTag    String
  keyFingerprint      String
  keyVersion          Int          @default(1)
  status              ApiKeyStatus @default(ACTIVE)
  lastValidatedAt     DateTime?
  lastError           String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  portfolioSnapshots  PortfolioSnapshot[]
  positionSnapshots   PositionSnapshot[]

  @@index([userId, exchange, status])
  @@unique([userId, exchange, keyFingerprint])
}

model PortfolioSnapshot {
  id                String                 @id @default(cuid())
  userId            String
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId      String
  credential        UserExchangeCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  exchange          String                 @default("bybit")
  accountType       String?
  totalEquity       Decimal?               @db.Decimal(30, 12)
  availableBalance  Decimal?               @db.Decimal(30, 12)
  maintenanceMargin Decimal?               @db.Decimal(30, 12)
  initialMargin     Decimal?               @db.Decimal(30, 12)
  raw               Json
  createdAt         DateTime               @default(now())

  @@index([userId, exchange, createdAt])
  @@index([credentialId, createdAt])
}

model PositionSnapshot {
  id               String                 @id @default(cuid())
  userId           String
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId     String
  credential       UserExchangeCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  exchange         String                 @default("bybit")
  marketType       MarketType             @default(LINEAR)
  symbol           String
  side             String
  contracts        Decimal?               @db.Decimal(30, 12)
  entryPrice       Decimal?               @db.Decimal(30, 12)
  markPrice        Decimal?               @db.Decimal(30, 12)
  notional         Decimal?               @db.Decimal(30, 12)
  leverage         Decimal?               @db.Decimal(18, 8)
  unrealizedPnl    Decimal?               @db.Decimal(30, 12)
  pnlPct           Decimal?               @db.Decimal(18, 8)
  liquidationPrice Decimal?               @db.Decimal(30, 12)
  marginMode       String?
  raw              Json
  createdAt        DateTime               @default(now())

  @@index([userId, symbol, createdAt])
  @@index([userId, createdAt])
  @@index([credentialId, createdAt])
}
