# Skopiuj: cp .env.example .env
# Docker Compose ładuje ten plik do kontenerów web, worker i migrate (env_file: .env).

# --- Baza i Redis ---
# Docker Compose: hosty to NAZWY SERWISÓW (postgres, redis), nie localhost.
POSTGRES_USER=screener
POSTGRES_PASSWORD=screener
POSTGRES_DB=screener
DATABASE_URL=postgresql://screener:screener@postgres:5432/screener?schema=public
REDIS_URL=redis://redis:6379

# Lokalny dev BEZ Dockera (npm run dev na hoście) — odkomentuj i zakomentuj linie powyżej:
# DATABASE_URL=postgresql://screener:screener@localhost:5432/screener?schema=public
# REDIS_URL=redis://localhost:6379

# --- Aplikacja ---
# Publiczny URL widoczny w przeglądarce (nie adres wewnętrzny kontenera).
# Lokalnie z Dockerem: http://localhost:3011
# Na VPS: http://TWOJE-IP:3011 lub https://twoja-domena.pl
NEXT_PUBLIC_APP_URL=http://localhost:3011

# Opcjonalnie po pierwszym deployu — dane demo:
# docker compose run --rm worker npm run db:seed

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Bezpieczeństwo ---
ENCRYPTION_KEY=change-me-to-32-char-secret-key!!
# Wymagany do szyfrowania Bybit API credentials. Użyj 32-byte base64 albo 64-char hex.
# Wygeneruj: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
API_CREDENTIAL_ENCRYPTION_KEY=WKLEJ_TUTAJ_WYNIK_Z_NODE_RANDOMBYTES_32_BASE64
